#!/bin/bash
# Global pre-push hook: block pushes to main and force pushes.

ZERO="0000000000000000000000000000000000000000"

while read local_ref local_sha remote_ref remote_sha; do

    # Block any push to main or master
    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            echo "ERROR: Pushing to $remote_ref is blocked. Use a pull request." >&2
            exit 1
            ;;
    esac

    # Block force pushes (remote branch already exists, push is non-fast-forward)
    if [ "$remote_sha" != "$ZERO" ] && [ "$local_sha" != "$ZERO" ]; then
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            echo "ERROR: Force push to $remote_ref is blocked." >&2
            exit 1
        fi
    fi

done

exit 0
